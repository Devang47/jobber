# Discord - Get your token from browser DevTools (Network tab > any request > Authorization header)
DISCORD_TOKEN=your_personal_discord_token_here

# Discord Server IDs to monitor (comma-separated)
# Join these servers first using the invite links below, then add their IDs:
#
# Freelance Marketplace (61K members)    — https://discord.com/invite/freelance-marketplace-1002522561613135892
# For Hire (37K members)                 — https://discord.com/invite/for-hire-hire-or-get-hired-fiverr-upwork-jobs-944133153105276979
# Devs For Hire & Jobs (27K members)     — https://discord.com/invite/awHZtSf89q         (ID: 880546729349488741)
# NextJob (15K members)                  — https://discord.com/invite/ZEH6eJucrF         (ID: 1224897044259278858)
# Freelanzo (13K members)               — https://discord.com/invite/freelanzo-hire-jobs-freelance-1237622676449792073
# Skill Forge (10K members)             — https://discord.com/invite/skill-forge-freelancing-jobs-hire-1193785569138978816
# Freelance Hub                         — https://discord.com/invite/advertising-hub-freelance-jobs-hire-1137726416503443469
# Jobs & Hiring Market                  — https://discord.com/invite/jobs-hiring-market-business-freelancing-jobs-smma-1024730510880165968
# Hire Developers                       — https://discord.com/invite/hiredevelopers       (ID: 460914492671524865)
#
DISCORD_SERVER_IDS=1002522561613135892,944133153105276979,880546729349488741,1224897044259278858,1237622676449792073,1193785569138978816,1137726416503443469,1024730510880165968,460914492671524865

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# Telegram Bot — Create via @BotFather, get chat ID via /getUpdates
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_group_chat_id

# Pre-filter settings
MIN_MESSAGE_LENGTH=50
PREFILTER_KEYWORDS=hiring,looking for,freelance,remote,contract,developer,designer,gig,project,budget,pay,rate,deadline,apply,opportunity,position,role

# Behavior
LOG_LEVEL=INFO
RECONNECT_DELAY_SECONDS=5
MAX_RECONNECT_ATTEMPTS=10
TELEGRAM_COOLDOWN_SECONDS=30
